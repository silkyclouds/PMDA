# Local Cursor rules – never publish to GitHub
.cursorrules
.codex/

# Never push to GitHub: Cursor IDE, docs (README.md is allowed)
.cursor/
docs/
*.md
!README.md
!docs/
!docs/README.md
!docs/USER_GUIDE.md
!docs/ARCHITECTURE.md
!docs/CONFIGURATION.md
!docs/UNRAID_POWER_SAVER_SCAN.md
frontend/README.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/

# Test / dev only – not for GitHub or production image
local-test-config/
scripts/
!scripts/
scripts/*
!scripts/build_with_classical_gate.sh
!scripts/pipeline_audit_gate.py
!scripts/legacy_cleanup_gate.py
!scripts/autonomous_refactor_guard.py
static/
frontend/.git
frontend/node_modules
frontend/dist

# Config / state – not needed at runtime (SQLite is source of truth)
ai_prompt.txt
config.json
state.db
settings.db
cache.db
pmda.log
pmda.log.*

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
*.swo
*.tsbuildinfo
